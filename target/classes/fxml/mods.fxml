<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            style="-fx-background-color: #0a0e17;">

    <left>
        <VBox style="-fx-pref-width: 350; -fx-background-color: #0d1321;">
            
            <HBox style="-fx-padding: 20; -fx-background-color: #0a0e17;">
                <Label text="🧩 Моды" 
                       style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #00d4ff;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+" 
                        style="-fx-background-color: #00d4ff; -fx-text-fill: #000; 
                               -fx-font-size: 18; -fx-font-weight: bold;
                               -fx-min-width: 35; -fx-min-height: 35;"/>
            </HBox>
            
            <Separator style="-fx-background-color: #1a2332;"/>
            
            <ListView style="-fx-background-color: transparent; -fx-padding: 10;" VBox.vgrow="ALWAYS"/>
            
        </VBox>
    </left>

    <center>
        <VBox style="-fx-padding: 30;" spacing="20">
            
            <Label text="Загрузка модов" 
                   style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: white;"/>
            
            <HBox spacing="10">
                <TextField promptText="Поиск модов..." 
                           style="-fx-background-color: #1a2332; -fx-text-fill: white; 
                                  -fx-pref-width: 300;"/>
                <Button text="🔍 Поиск" 
                        style="-fx-background-color: #00d4ff; -fx-text-fill: #000;"/>
            </HBox>
            
            <Label text="Популярные моды" 
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #00d4ff;"/>
            
            <GridPane hgap="15" vgap="15">
                <!-- Моды будут добавлены динамически -->
            </GridPane>
            
        </VBox>
    </center>

</BorderPane>

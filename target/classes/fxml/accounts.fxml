<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.quantumlauncher.ui.controller.AccountsController"
      style="-fx-background-color: #0a0e17;"
      spacing="20">
    
    <padding>
        <Insets top="30" left="30" right="30" bottom="30"/>
    </padding>
    
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="🔐 Управление аккаунтами"
               style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
    </HBox>
    
    <Separator style="-fx-background-color: #1a2332;"/>
    
    <!-- Description -->
    <VBox spacing="5">
        <Label text="Добавьте аккаунт Microsoft для игры на лицензии."
               style="-fx-font-size: 14; -fx-text-fill: #aaaaaa;"/>
        <Label text="Авторизация происходит через Device Flow - безопасный способ входа."
               style="-fx-font-size: 12; -fx-text-fill: #666666;"/>
    </VBox>
    
    <!-- Buttons -->
    <HBox spacing="10">
        <Button fx:id="btnAddMicrosoft" text="➕ Добавить Microsoft аккаунт"
                style="-fx-background-color: #0078d4; -fx-text-fill: white; -fx-font-size: 14; -fx-padding: 10 20;"/>
        
        <Button fx:id="btnRemove" text="🗑️ Удалить"
                style="-fx-background-color: #d13438; -fx-text-fill: white; -fx-font-size: 14; -fx-padding: 10 20;"/>
        
        <Button fx:id="btnSetDefault" text="⭐ По умолчанию"
                style="-fx-background-color: #107c10; -fx-text-fill: white; -fx-font-size: 14; -fx-padding: 10 20;"/>
        
        <ProgressIndicator fx:id="progressIndicator" visible="false"
                           style="-fx-progress-color: #00d4ff;"/>
    </HBox>
    
    <!-- Account List -->
    <VBox VBox.vgrow="ALWAYS" spacing="10">
        <Label text="Ваши аккаунты:"
               style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
        
        <ListView fx:id="accountListView" 
                  style="-fx-background-color: #0d1321; -fx-border-color: #1a2332;"
                  VBox.vgrow="ALWAYS">
            <VBox.margin>
                <Insets top="10"/>
            </VBox.margin>
        </ListView>
    </VBox>
    
    <!-- Status Bar -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Separator HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusLabel" text="Готов"
               style="-fx-font-size: 12; -fx-text-fill: #888888;"/>
    </HBox>
    
</VBox>

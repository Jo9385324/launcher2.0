<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.quantumlauncher.ui.controller.MainController"
            style="-fx-background-color: #0a0e17;">

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- LEFT SIDEBAR - Navigation -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <left>
        <VBox spacing="0" style="-fx-background-color: #0d1321; -fx-pref-width: 220;">
            
            <!-- Logo Section -->
            <StackPane style="-fx-pref-height: 80; -fx-background-color: #0d1321;">
                <Text text="Quantum" 
                      style="-fx-font-size: 24; -fx-font-weight: bold; -fx-fill: #00d4ff;" 
                      StackPane.alignment="CENTER_LEFT">
                    <StackPane.margin>
                        <Insets left="20"/>
                    </StackPane.margin>
                </Text>
                <Text text="Launcher" 
                      style="-fx-font-size: 24; -fx-font-weight: bold; -fx-fill: #ffffff;" 
                      StackPane.alignment="CENTER_RIGHT">
                    <StackPane.margin>
                        <Insets right="40"/>
                    </StackPane.margin>
                </Text>
            </StackPane>
            
            <Separator style="-fx-background-color: #1a2332;"/>
            
            <!-- Navigation Menu -->
            <VBox spacing="5" style="-fx-padding: 20 10;">
                
                <Button fx:id="btnInstances" text="🎮  Инстансы" 
                        styleClass="nav-button"
                        onAction="#showInstances"/>

                <Button fx:id="btnMods" text="🧩  Моды" 
                        styleClass="nav-button"
                        onAction="#showMods"/>

                <Button fx:id="btnShaders" text="🎮  Шейдеры" 
                        styleClass="nav-button"
                        onAction="#showShaders"/>

                <Button fx:id="btnTexturePacks" text="🎨  Текстур-паки" 
                        styleClass="nav-button"
                        onAction="#showTexturePacks"/>

                <Button fx:id="btnMaps" text="🗺️  Карты" 
                        styleClass="nav-button"
                        onAction="#showMaps"/>

                <Separator style="-fx-background-color: #1a2332; -fx-padding: 10 0;"/>

                <Button fx:id="btnForks" text="🍴  Сборки" 
                        styleClass="nav-button"
                        onAction="#showForks"/>

                <Button fx:id="btnAccounts" text="🔐  Аккаунты" 
                        styleClass="nav-button"
                        onAction="#showAccounts"/>

                <Button fx:id="btnSkins" text="👤  Скины" 
                        styleClass="nav-button"
                        onAction="#showSkins"/>

                <Separator style="-fx-background-color: #1a2332; -fx-padding: 10 0;"/>
                
                <Button fx:id="btnAI" text="🤖  AI Помощник" 
                        styleClass="nav-button"
                        onAction="#showAI"/>

                <Button fx:id="btnSettings" text="⚙️  Настройки" 
                        styleClass="nav-button"
                        onAction="#showSettings"/>

            </VBox>
            
            <!-- Spacer -->
            <Region VBox.vgrow="ALWAYS"/>
            
            <!-- Profile Section -->
            <VBox style="-fx-padding: 15; -fx-background-color: #0a0e17;" 
                  alignment="CENTER">
                <HBox alignment="CENTER" spacing="10">
                    <ImageView fx:id="profileAvatar" fitWidth="40" fitHeight="40">
                        <image>
                            <Image url="@/images/default-avatar.png" preserveRatio="true"/>
                        </image>
                    </ImageView>
                    <VBox>
                        <Label fx:id="profileName" text="Игрок" 
                               style="-fx-text-fill: #ffffff; -fx-font-size: 14; -fx-font-weight: bold;"/>
                        <Label fx:id="profileStatus" text="Оффлайн" 
                               style="-fx-text-fill: #666666; -fx-font-size: 11;"/>
                    </VBox>
                </HBox>
            </VBox>
            
        </VBox>
    </left>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- CENTER - Content Area -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #0a0e17;">
            <!-- Default content will be set by controller -->
        </StackPane>
    </center>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- BOTTOM - Status Bar -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <bottom>
        <HBox style="-fx-background-color: #0d1321; -fx-pref-height: 35; -fx-padding: 0 15;"
              alignment="CENTER_LEFT">
            
            <Label fx:id="fpsLabel" text="FPS: --" 
                   style="-fx-text-fill: #00ff88; -fx-font-size: 12;"/>
            
            <Region HBox.hgrow="ALWAYS"/>
            
            <Label fx:id="ramLabel" text="RAM: --" 
                   style="-fx-text-fill: #00d4ff; -fx-font-size: 12;"/>
            
            <Separator orientation="VERTICAL" style="-fx-padding: 0 15;"/>
            
            <Label fx:id="cpuLabel" text="CPU: --" 
                   style="-fx-text-fill: #ff6b6b; -fx-font-size: 12;"/>
            
        </HBox>
    </bottom>

</BorderPane>

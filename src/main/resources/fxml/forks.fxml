<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            style="-fx-background-color: #0a0e17;">

    <center>
        <VBox style="-fx-padding: 30;" spacing="20">
            
            <Label text="🍴 Кастомные сборки" 
                   style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #00d4ff;"/>
            
            <HBox spacing="15">
                <ComboBox promptText="Версия Minecraft" 
                          style="-fx-background-color: #1a2332; -fx-text-fill: white;">
                    <items>
                        <String fx:value="1.20.4"/>
                        <String fx:value="1.20.3"/>
                        <String fx:value="1.19.4"/>
                    </items>
                </ComboBox>
                <ComboBox promptText="ModLoader" 
                          style="-fx-background-color: #1a2332; -fx-text-fill: white;">
                    <items>
                        <String fx:value="Fabric"/>
                        <String fx:value="Forge"/>
                        <String fx:value="Quilt"/>
                    </items>
                </ComboBox>
                <Button text="Найти" 
                        style="-fx-background-color: #00d4ff; -fx-text-fill: #000;"/>
            </HBox>
            
            <Label text="Популярные сборки" 
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;"/>
            
            <VBox spacing="10">
                <!-- Сборки будут отображаться здесь -->
                <Label text="Загрузка сборок..." style="-fx-text-fill: #666;"/>
            </VBox>
            
        </VBox>
    </center>

</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.quantumlauncher.ui.controller.InstancesController"
            style="-fx-background-color: #0a0e17;">

    <!-- Left Panel - Список инстансов -->
    <left>
        <VBox style="-fx-pref-width: 350; -fx-background-color: #0d1321;">
            
            <!-- Header -->
            <HBox style="-fx-padding: 20; -fx-background-color: #0a0e17;">
                <Label text="🎮 Инстансы" 
                       style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #00d4ff;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="createButton" text="+" 
                        style="-fx-background-color: #00d4ff; -fx-text-fill: #000; 
                               -fx-font-size: 18; -fx-font-weight: bold;
                               -fx-min-width: 35; -fx-min-height: 35;
                               -fx-background-radius: 17;"/>
            </HBox>
            
            <Separator style="-fx-background-color: #1a2332;"/>
            
            <!-- List -->
            <ListView fx:id="instancesListView" 
                      style="-fx-background-color: transparent; -fx-padding: 10;"
                      VBox.vgrow="ALWAYS"/>
            
        </VBox>
    </left>

    <!-- Center - Details Panel -->
    <center>
        <VBox fx:id="detailsPanel" visible="false" 
              style="-fx-padding: 30;" spacing="20">
            
            <!-- Instance Info -->
            <VBox spacing="10">
                <Label fx:id="instanceNameLabel" 
                       style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: white;"/>
                
                <HBox spacing="20">
                    <VBox>
                        <Label text="Версия" style="-fx-text-fill: #666; -fx-font-size: 12;"/>
                        <Label fx:id="instanceVersionLabel" style="-fx-text-fill: white;"/>
                    </VBox>
                    <VBox>
                        <Label text="ModLoader" style="-fx-text-fill: #666; -fx-font-size: 12;"/>
                        <Label fx:id="instanceModloaderLabel" style="-fx-text-fill: white;"/>
                    </VBox>
                    <VBox>
                        <Label text="Статус" style="-fx-text-fill: #666; -fx-font-size: 12;"/>
                        <Label fx:id="instanceStatusLabel" style="-fx-text-fill: #00ff88;"/>
                    </VBox>
                </HBox>
                
                <Label fx:id="lastPlayedLabel" style="-fx-text-fill: #666; -fx-font-size: 12;"/>
            </VBox>
            
            <Separator style="-fx-background-color: #1a2332;"/>
            
            <!-- RAM Settings -->
            <VBox spacing="10">
                <Label text="Оперативная память" 
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;"/>
                
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Slider fx:id="ramSlider" min="1024" max="16384" 
                            value="4096" showTickLabels="true" 
                            style="-fx-pref-width: 300;"/>
                    <Label fx:id="ramLabel" text="4096 MB" 
                           style="-fx-text-fill: #00d4ff; -fx-font-size: 14;"/>
                </HBox>
            </VBox>
            
            <Separator style="-fx-background-color: #1a2332;"/>
            
            <!-- Actions -->
            <HBox spacing="15">
                <Button fx:id="launchButton" text="🚀 Запустить" 
                        style="-fx-background-color: #00ff88; -fx-text-fill: #000;
                               -fx-font-size: 16; -fx-font-weight: bold;
                               -fx-padding: 15 30; -fx-background-radius: 8;"/>
                
                <Button fx:id="stopButton" text="⏹ Остановить" 
                        disable="true"
                        style="-fx-background-color: #ff6b6b; -fx-text-fill: #000;
                               -fx-font-size: 16; -fx-font-weight: bold;
                               -fx-padding: 15 30; -fx-background-radius: 8;"/>
                
                <Button fx:id="deleteButton" text="🗑 Удалить" 
                        style="-fx-background-color: #1a2332; -fx-text-fill: #ff6b6b;
                               -fx-font-size: 16;
                               -fx-padding: 15 30; -fx-background-radius: 8;"/>
            </HBox>
            
        </VBox>
    </center>

</BorderPane>

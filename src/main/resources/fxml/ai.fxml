<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.quantumlauncher.ui.controller.AIController"
            style="-fx-background-color: #0a0e17;">

    <center>
        <VBox style="-fx-padding: 30;" spacing="20">
            
            <Label text="🤖 AI Ассистент" 
                   style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #00d4ff;"/>
            
            <!-- AI Функции -->
            <HBox spacing="20">
                
                <!-- Анализ конфликтов -->
                <VBox spacing="10" style="-fx-background-color: #0d1321; -fx-padding: 20; 
                                         -fx-background-radius: 12; -fx-pref-width: 250;">
                    <Label text="🔍 Анализ конфликтов" 
                           style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Проверка модов на совместимость" 
                           style="-fx-text-fill: #888; -fx-font-size: 12;" wrapText="true"/>
                    <Button text="Анализировать" 
                            style="-fx-background-color: #00d4ff; -fx-text-fill: #000;
                                   -fx-padding: 10 20;"/>
                </VBox>
                
                <!-- Оптимизация -->
                <VBox spacing="10" style="-fx-background-color: #0d1321; -fx-padding: 20; 
                                         -fx-background-radius: 12; -fx-pref-width: 250;">
                    <Label text="⚡ Оптимизация" 
                           style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Рекомендации по улучшению FPS" 
                           style="-fx-text-fill: #888; -fx-font-size: 12;" wrapText="true"/>
                    <Button text="Оптимизировать" 
                            style="-fx-background-color: #00ff88; -fx-text-fill: #000;
                                   -fx-padding: 10 20;"/>
                </VBox>
                
                <!-- Чат -->
                <VBox spacing="10" style="-fx-background-color: #0d1321; -fx-padding: 20; 
                                         -fx-background-radius: 12; -fx-pref-width: 250;">
                    <Label text="💬 AI Чат" 
                           style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Помощь в управлении лаунчером" 
                           style="-fx-text-fill: #888; -fx-font-size: 12;" wrapText="true"/>
                    <Button text="Начать диалог" 
                            style="-fx-background-color: #9b59b6; -fx-text-fill: #fff;
                                   -fx-padding: 10 20;"/>
                </VBox>
                
            </HBox>
            
            <Separator style="-fx-background-color: #1a2332;"/>
            
            <!-- Tab Pane -->
            <TabPane fx:id="aiTabPane" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">

                <!-- Chat Tab -->
                <Tab fx:id="chatTab" text="💬 Чат">
                    <VBox spacing="10" style="-fx-padding: 10;">
                        <Label text="Диалог с AI" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;"/>

                        <ListView fx:id="chatMessagesView"
                                  style="-fx-background-color: #0d1321; -fx-background-radius: 12;"
                                  VBox.vgrow="ALWAYS"/>

                        <HBox spacing="10">
                            <TextField fx:id="messageInput" promptText="Введите сообщение..."
                                       style="-fx-background-color: #1a2332; -fx-text-fill: white;
                                              -fx-pref-width: 500;"/>
                            <Button fx:id="sendButton" text="Отправить"
                                    style="-fx-background-color: #00d4ff; -fx-text-fill: #000;"/>
                        </HBox>
                    </VBox>
                </Tab>

                <!-- Analysis Tab -->
                <Tab fx:id="analysisTab" text="🔍 Анализ">
                    <VBox spacing="15" style="-fx-padding: 10;">
                        <Label text="Анализ конфликтов модов" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;"/>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Инстанс:" style="-fx-text-fill: white;"/>
                            <ComboBox fx:id="instanceSelector" promptText="Выберите инстанс"
                                      style="-fx-background-color: #1a2332; -fx-text-fill: white; -fx-pref-width: 200;"/>
                            <Button fx:id="analyzeButton" text="Анализировать"
                                    style="-fx-background-color: #00d4ff; -fx-text-fill: #000; -fx-padding: 8 16;"/>
                            <ProgressIndicator fx:id="analysisProgress" visible="false" style="-fx-progress-color: #00d4ff;"/>
                        </HBox>

                        <TextArea fx:id="analysisResult" editable="false"
                                  style="-fx-background-color: #0d1321; -fx-text-fill: #00ff88;
                                         -fx-font-family: 'Consolas'; -fx-font-size: 13;"
                                  VBox.vgrow="ALWAYS"/>
                    </VBox>
                </Tab>

            </TabPane>

        </VBox>
    </center>

</BorderPane>
